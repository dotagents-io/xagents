{
  "name": "@dotagents-io/xagents",
  "version": "1.0.2",
  "description": "Sync AGENTS.md files with configuration files across your project",
  "type": "module",
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "xagents": "./dist/index.js"
  },
  "files": [
    "dist/index.js",
    "dist/core.js",
    "dist/discovery.js",
    "dist/validator.js"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:spec": "vitest run --reporter=verbose",
    "publish:patch": "npm run build && npm version patch && npm publish"
  },
  "keywords": [
    "dotagents",
    "agents",
    "agents-md",
    "ai-coding-tools",
    "mcp",
    "claude",
    "claude-code",
    "cursor",
    "codex",
    "gemini",
    "kiro",
    "opencode",
    "windsurf",
    "codeium",
    "devin",
    "copilot",
    "configuration",
    "interoperability",
    "context"
  ],
  "author": "dotagents community",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dotagents-io/xagents.git"
  },
  "homepage": "https://dotagents.io",
  "bugs": {
    "url": "https://github.com/dotagents-io/xagents/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "typescript": "^5.3.3",
    "vitest": "^4.1.9"
  }
}
